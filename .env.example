# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Publique um prompt no langsmith hub para gerar seu username, depois abra o prompt e vá no simbolo de cadeado.
USERNAME_LANGSMITH_HUB=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GOOGLE_API_KEY=

# LLM Configuration
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
EVAL_MODEL=gemini-2.5-flash

#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini
#EVAL_MODEL=gpt-4o

# Prompt de origem para pull e caminho de saída local
LANGSMITH_PULL_PROMPT=leonanluppi/bug_to_user_story_v1
PROMPT_OUTPUT_PATH=prompts/bug_to_user_story_v1.yml
PROMPT_V2_PATH=prompts/bug_to_user_story_v2.yml
